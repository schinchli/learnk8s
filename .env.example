# Copy this to .env.local and fill in values
# Do NOT commit .env.local

SUPABASE_URL=https://swydybtzyjxftzfzqqnv.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# OpenAI — used ONLY for embeddings (text-embedding-3-small)
# Anthropic has no embeddings API; this is ~$0.02 one-time for the whole corpus
OPENAI_API_KEY=<your-openai-key>

# Anthropic — used for generation (Claude Haiku / Sonnet)
ANTHROPIC_API_KEY=<your-anthropic-key>
